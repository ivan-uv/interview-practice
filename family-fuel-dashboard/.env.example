# API Keys — copy this file to .env and fill in your values
# Never commit .env to version control

# Spoonacular API (https://spoonacular.com/food-api)
# Free tier: 50 points/day — requires credit card to sign up
SPOONACULAR_KEY=your_spoonacular_api_key_here

# USDA FoodData Central API (https://api.data.gov)
# Free: 1,000 req/hr — no credit card required
USDA_KEY=your_usda_api_key_here

# Open Food Facts — no key required, just set a descriptive User-Agent
OFF_USER_AGENT=FamilyFuelDashboard/1.0 (your@email.com)

# Optional: path to DuckDB file (defaults to data/family_fuel.duckdb)
# DUCKDB_PATH=data/family_fuel.duckdb
